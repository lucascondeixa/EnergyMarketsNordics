# Copy to .env and fill in your keys. .env is gitignored.

# ENTSO-E Transparency Platform token
# Register free at https://transparency.entsoe.eu → My Account → Security tokens
ENTSOE_API_KEY=your_entsoe_token_here

# Fingrid Open Data API key
# Register free at https://data.fingrid.fi → Sign in → API keys
FINGRID_API_KEY=your_fingrid_key_here
