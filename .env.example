# Copy this file to .env and fill in your keys. Never commit .env.
#
# Fingrid Open Data API — free registration at https://data.fingrid.fi
# Used for: FCR-N capacity prices (dataset 84), nuclear/hydro production actuals
FINGRID_API_KEY=your_fingrid_api_key_here

# ENTSO-E Transparency Platform — free registration at https://transparency.entsoe.eu
# Used for: FI and SE2 day-ahead Elspot prices (document type A44)
ENTSOE_API_KEY=your_entsoe_token_here
